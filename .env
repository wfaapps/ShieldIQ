# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# IMPORTANT FOR GCP DEPLOYMENT:
# Change these from localhost to your GCP VM's IP address or Domain Name
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://shieldiq:changeme@localhost:5432/shieldiq

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME_32_PLUS_RANDOM_CHARS_HERE
# Generate with: openssl rand -hex 32
MFA_ENCRYPTION_KEY=CHANGE_ME_32_RANDOM_BYTES_HEX
# Generate with: openssl rand -base64 32
CSRF_SECRET=CHANGE_ME_32_PLUS_RANDOM_CHARS_HERE
# Generate with: openssl rand -base64 32
PHISH_HMAC_SECRET=CHANGE_ME_32_PLUS_RANDOM_CHARS_HERE

# ─── Email ────────────────────────────────────────────────────────────────────
# IMPORTANT FOR GCP DEPLOYMENT (Replace with your actual SendGrid credentials)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=YOUR_SENDGRID_API_KEY_HERE
SMTP_FROM=security@yourcompany.com

# ─── Storage (optional S3-compatible) ─────────────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=
S3_KEY=
S3_SECRET=
