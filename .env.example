# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://yourapp.com
NEXT_PUBLIC_API_URL=https://yourapp.com/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://shieldiq:changeme@localhost:5432/shieldiq

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME_32_PLUS_RANDOM_CHARS_HERE
# Generate with: openssl rand -hex 32
MFA_ENCRYPTION_KEY=CHANGE_ME_32_RANDOM_BYTES_HEX
# Generate with: openssl rand -base64 32
CSRF_SECRET=CHANGE_ME_32_PLUS_RANDOM_CHARS_HERE
# Generate with: openssl rand -base64 32
PHISH_HMAC_SECRET=CHANGE_ME_32_PLUS_RANDOM_CHARS_HERE

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=secret
SMTP_FROM=security@company.com

# ─── Storage (optional S3-compatible) ─────────────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=
S3_KEY=
S3_SECRET=
